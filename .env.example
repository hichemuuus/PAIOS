# Veyron environment variables. Copy to .env and edit. .env is gitignored.

# Env vars use the VEYRON_ prefix and __ for nesting. They override config.yaml.
# VEYRON_ENVIRONMENT=dev
# VEYRON_DATABASE_URL=sqlite:///backend/data/veyron.db

# VEYRON_MODEL__OLLAMA_URL=http://localhost:11434
# VEYRON_MODEL__BASE_MODEL=qwen2.5:3b-instruct
# VEYRON_MODEL__REMOTE_ENABLED=true
# VEYRON_MODEL__REMOTE_URL=https://api.openai.com/v1
# VEYRON_MODEL__REMOTE_API_KEY=sk-...
# VEYRON_MODEL__REMOTE_MODEL=gpt-4o-mini

# VEYRON_SECURITY__CONFIRM_TIMEOUT_SECONDS=120
# VEYRON_SECURITY__SANDBOX_ROOTS=["C:\\Users\\YourUsername"]
